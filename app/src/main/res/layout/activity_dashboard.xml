<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:titleTextColor="#111827" />

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EduBudget"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1F2A37"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back 👋"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="20dp"/>

        <!-- BALANCE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:id="@+id/totalExpensesText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Expenses: R0"
                android:textColor="#6B7280"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/expenseCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Number of Expenses: 0"
                android:textColor="#111827"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <!-- QUICK ACTIONS TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <!-- ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnExpense"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:text="➕ Add Expense"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4F46E5"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnGoal"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:text="📊 Budget Goal"
                android:textColor="#FFFFFF"
                android:backgroundTint="#10B981"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnViewExpenses"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:text="📜 History"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3B82F6"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnCategory"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:text="⚙ Categories"
                android:textColor="#FFFFFF"
                android:backgroundTint="#6B7280"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secure • Simple • Smart"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            android:layout_marginTop="28dp"/>

    </LinearLayout>

</ScrollView>